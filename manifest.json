{
  "manifest_version": 3,
  "name": "EnviroFlow",
  "version": "1.0.0",
  "description": "A Chrome extension that optimizes AI prompts to reduce carbon, energy, and token usage.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://copilot.microsoft.com/*",
        "https://bing.com/*",
        "https://www.bing.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://poe.com/*",
        "https://character.ai/*",
        "https://you.com/*",
        "<all_urls>"
      ],
      "js": [
        "optimizer.js",
        "content.js"
      ]
    }
  ]
}
